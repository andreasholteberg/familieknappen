# Familieknappen – Supabase-konfigurasjon
# Kopier denne fila til .env og fyll inn verdiene fra Supabase-prosjektet ditt
# (Project Settings → API). Variabler med EXPO_PUBLIC_-prefiks er tilgjengelige
# i klienten via process.env.

EXPO_PUBLIC_SUPABASE_URL=https://DITT-PROSJEKT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=din-anon-public-key
