# Familieknappen - Supabase-konfigurasjon
# Kopier denne fila til .env og fyll inn verdiene fra Supabase:
#   Project Settings -> API
#
# VIKTIG: Bruk KUN den offentlige nokkelen i appen:
#   - ny stil: "Publishable key" (sb_publishable_...)
#   - eller legacy: "anon public" (en lang eyJ... JWT med role=anon)
# ALDRI bruk "service_role" / "secret key" (sb_secret_...) i appen.
# EXPO_PUBLIC_*-variabler bakes inn i klient-bundelen og er dermed offentlige.
# GitHub Pages-workflowen bruker de samme variabelnavnene som Repository Variables.

EXPO_PUBLIC_SUPABASE_URL=https://DITT-PROSJEKT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=DIN_PUBLIC_ANON_KEY

# Midlertidig testinnlogging for development/preview APK-testing.
# Ikke sett EXPO_PUBLIC_ENABLE_TEST_LOGIN=true i production.
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_ENABLE_TEST_LOGIN=false
EXPO_PUBLIC_TEST_LOGIN_EMAILS=test1@example.no,test2@example.no
